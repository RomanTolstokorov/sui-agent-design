{
  "mcpServers": {
    "atlassian-jira": {
      "type": "http",
      "url": "http://localhost:4040/mcp"
    },
    "teletronics-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://ssystem-mcp.teletronics.local:30443/mcp"
      ],
      "env": {
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    }
  }
}
