  "readOnlyPreview": {
    "task": {
      "composition": {
        "firstBlock": "subject",
        "sectionModel": "stackedFormBlocks",
        "allowedBlockSource": "wrappers where appliesToEntities includes task",
        "wrapperBehavior": "Use the full <Form Blocks> | ... instance. Keep its title, icon, actions, toolbar, and content shell when provided by the component.",
        "contentBehavior": "Use <Form Blocks Content> | ... only inside an existing wrapper or documented custom shell."
      },
      "rules": [
        "Place <Form Blocks> | Subject before all other task preview content.",
        "After Subject, choose task-visible sections from workflow state and appliesToEntities.",
        "Do not strip wrapper titles from task read-only sections."
      ]
    },
    "document": {
      "composition": {
        "firstBlock": "subject",
        "secondBlock": "documentPreview",
        "sectionModel": "subjectPlusTabbedReadyPreview",
        "readyComponent": "documentPreview",
        "defaultTab": "document",
        "variantProperty": "Tab"
      },
      "rules": [
        "Place <Form Blocks> | Subject first.",
        "Place the ready <Document preview> component immediately after Subject.",
        "Switch document preview content with the Tab variant.",
        "Do not assemble document read-only preview from multiple <Form Blocks> | ... wrappers under the tabs.",
        "If a needed tab has no ready variant, draw only the tab content body and omit <Form Blocks Component> | Title because the tabs own the section title."
      ]
    }
  },
