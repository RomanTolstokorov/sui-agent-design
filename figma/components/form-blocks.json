  "rules": [
    "Use a <Form Blocks> | ... wrapper when the section needs its own header, icon, actions, and content shell.",
    "Use <Form Blocks Content> | ... only inside an existing wrapper or manually constructed section shell.",
    "Choose visible sections from workflow configuration plus appliesToEntities.",
    "Do not cross entity scopes unless a state doc explicitly overrides this registry.",
    "Place <Form Blocks> | Subject first in task and document previews.",
    "Build preview forms from readOnlyPreview composition rules.",
    "Task read-only previews use full <Form Blocks> | ... wrappers with title, toolbar, actions, and shell where the section component provides them.",
    "Document read-only previews use <Form Blocks> | Subject followed by the ready <Document preview> tabbed component.",
    "For document preview tabs, use the ready component as-is when one exists; only omit <Form Blocks Component> | Title when manually drawing new tab content.",
    "Documents and Temporary Documents are separate paths even when both reuse <DocumentListItem>.",
    "Use a ready attachment variant when its scenario matches the requested state."
  ],
  "entityApplicabilityModel": {
    "domainEntities": [
      "task",
      "document"
    ],
    "contexts": [
      "preview",
      "edit"
    ],
    "meaning": "appliesToEntities marks the entity being previewed or edited, not the host app. A document entity can appear in Task Management, Search, Documents, or another app surface."
  },
